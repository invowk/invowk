{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://invowk.dev/schemas/soundness-work-bundle.v2.schema.json",
  "title": "goplint distributed soundness work bundle v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version", "bundle_id", "plan_id", "work_unit_id",
    "workspace_digest", "manifest_digest", "registry_digest", "toolchain_digest",
    "command_digest", "binary_digest", "terminal_status", "binding", "report",
    "report_digest", "observations", "queued_at", "started_at", "finished_at",
    "wall_duration_nanoseconds", "cpu_time_nanoseconds", "peak_rss_bytes"
  ],
  "properties": {
    "format_version": { "const": 2 },
    "bundle_id": { "$ref": "#/$defs/digest" },
    "plan_id": { "$ref": "#/$defs/digest" },
    "work_unit_id": { "$ref": "#/$defs/identifier" },
    "workspace_digest": { "$ref": "#/$defs/digest" },
    "manifest_digest": { "$ref": "#/$defs/digest" },
    "registry_digest": { "$ref": "#/$defs/digest" },
    "toolchain_digest": { "$ref": "#/$defs/digest" },
    "command_digest": { "$ref": "#/$defs/digest" },
    "binary_digest": { "$ref": "#/$defs/digest" },
    "input_repository_audit_digest": { "$ref": "#/$defs/digest" },
    "output_repository_audit_digest": { "$ref": "#/$defs/digest" },
    "terminal_status": { "const": "passed" },
    "binding": { "$ref": "#/$defs/binding" },
    "report": { "$ref": "#/$defs/report" },
    "report_digest": { "$ref": "#/$defs/digest" },
    "observations": { "type": "array", "items": { "type": "object" } },
    "queued_at": { "type": "string", "format": "date-time" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "wall_duration_nanoseconds": { "type": "integer", "minimum": 0 },
    "cpu_time_nanoseconds": { "type": "integer", "minimum": 0 },
    "peak_rss_bytes": { "type": "integer", "minimum": 0 }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "identifier": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "workspace_digest", "manifest_digest", "command_digest", "subgate_id"],
      "properties": {
        "run_id": { "$ref": "#/$defs/identifier" },
        "workspace_digest": { "$ref": "#/$defs/digest" },
        "manifest_digest": { "$ref": "#/$defs/digest" },
        "command_digest": { "$ref": "#/$defs/digest" },
        "subgate_id": { "$ref": "#/$defs/identifier" }
      }
    },
    "population": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "count"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "count": { "type": "integer", "minimum": 1 }
      }
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format_version", "binding", "status", "populations"],
      "properties": {
        "format_version": { "const": 1 },
        "binding": { "$ref": "#/$defs/binding" },
        "status": { "const": "passed" },
        "populations": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/population" } }
      }
    }
  }
}
