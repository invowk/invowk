{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://invowk.dev/schemas/goplint/soundness-run-report.v1.schema.json",
  "title": "goplint retained aggregate soundness report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version",
    "profile",
    "run_id",
    "workspace_digest",
    "manifest_digest",
    "subgates",
    "observations"
  ],
  "properties": {
    "format_version": {
      "const": 1
    },
    "profile": {
      "enum": [
        "core",
        "complete"
      ]
    },
    "run_id": {
      "$ref": "#/$defs/identifier"
    },
    "workspace_digest": {
      "$ref": "#/$defs/digest"
    },
    "manifest_digest": {
      "$ref": "#/$defs/digest"
    },
    "subgates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/subgate_result"
      }
    },
    "observations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/observation"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "workspace_digest",
        "manifest_digest",
        "command_digest",
        "subgate_id"
      ],
      "properties": {
        "run_id": {
          "$ref": "#/$defs/identifier"
        },
        "workspace_digest": {
          "$ref": "#/$defs/digest"
        },
        "manifest_digest": {
          "$ref": "#/$defs/digest"
        },
        "command_digest": {
          "$ref": "#/$defs/digest"
        },
        "subgate_id": {
          "$ref": "#/$defs/identifier"
        }
      }
    },
    "population": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "count"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "subgate_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "command_digest",
        "report_digest",
        "populations"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "command_digest": {
          "$ref": "#/$defs/digest"
        },
        "report_digest": {
          "$ref": "#/$defs/digest"
        },
        "populations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/population"
          }
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome",
        "case_count",
        "diagnostic_count"
      ],
      "properties": {
        "outcome": {
          "type": "string"
        },
        "case_count": {
          "type": "integer",
          "minimum": 1
        },
        "diagnostic_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format_version",
        "binding",
        "registration_id",
        "category",
        "layer",
        "feature_id",
        "producer_id",
        "test_id",
        "boundary",
        "executed_boundaries",
        "result",
        "stages",
        "properties",
        "dimensions",
        "cases"
      ],
      "properties": {
        "format_version": {
          "const": 2
        },
        "binding": {
          "$ref": "#/$defs/binding"
        },
        "registration_id": {
          "$ref": "#/$defs/identifier"
        },
        "category": {
          "$ref": "#/$defs/identifier"
        },
        "layer": {
          "type": "string"
        },
        "feature_id": {
          "$ref": "#/$defs/identifier"
        },
        "producer_id": {
          "$ref": "#/$defs/identifier"
        },
        "test_id": {
          "$ref": "#/$defs/identifier"
        },
        "boundary": {
          "type": "string"
        },
        "executed_boundaries": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "result": {
          "$ref": "#/$defs/result"
        },
        "stages": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "properties": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "dimensions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/semantic_case"
          }
        }
      }
    },
    "semantic_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "layer",
        "feature_id",
        "boundary",
        "executed_boundaries",
        "outcome",
        "diagnostic_count",
        "stages",
        "properties",
        "dimensions"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "category": {
          "$ref": "#/$defs/identifier"
        },
        "layer": {
          "type": "string"
        },
        "feature_id": {
          "$ref": "#/$defs/identifier"
        },
        "boundary": {
          "type": "string"
        },
        "executed_boundaries": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "outcome": {
          "type": "string"
        },
        "diagnostic_count": {
          "type": "integer",
          "minimum": 0
        },
        "stages": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "properties": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "dimensions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        }
      }
    }
  }
}
