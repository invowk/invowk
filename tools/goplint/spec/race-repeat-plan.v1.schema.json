{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://invowk.dev/schemas/race-repeat-plan.v1.schema.json",
  "title": "goplint race/repeat execution plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version", "plan_id", "workspace_digest", "toolchain", "package",
    "timing", "census_digest", "census", "environment", "binaries", "repeat_count",
    "shard_count", "work_units", "defaulted_member_ids"
  ],
  "properties": {
    "format_version": { "const": 1 },
    "plan_id": { "$ref": "#/$defs/digest" },
    "workspace_digest": { "$ref": "#/$defs/digest" },
    "toolchain": { "type": "string", "minLength": 1 },
    "package": { "type": "string", "minLength": 1 },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "digest"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "census_digest": { "$ref": "#/$defs/digest" },
    "census": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/census_entry" }
    },
    "environment": {
      "type": "array",
      "const": ["GOPLINT_PROTOCOL_ORACLE_PROFILE=scheduled"]
    },
    "binaries": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/binary" }
    },
    "repeat_count": { "type": "integer", "minimum": 1 },
    "shard_count": { "type": "integer", "minimum": 1 },
    "work_units": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/work_unit" }
    },
    "defaulted_member_ids": {
      "type": "array",
      "items": { "$ref": "#/$defs/member_id" },
      "uniqueItems": true
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "member_id": { "type": "string", "pattern": "^(Test|Fuzz|Example)[A-Za-z0-9_]*$" },
    "census_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": { "$ref": "#/$defs/member_id" },
        "kind": { "enum": ["test", "fuzz", "example"] }
      }
    },
    "binary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "file_name", "digest"],
      "properties": {
        "mode": { "enum": ["normal", "race"] },
        "file_name": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "work_unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "mode", "iteration", "member_ids", "total_weight",
        "timeout_seconds", "binary_digest"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["normal", "race"] },
        "iteration": { "type": "integer", "minimum": 1 },
        "member_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/member_id" },
          "uniqueItems": true
        },
        "total_weight": { "type": "integer", "minimum": 1 },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "binary_digest": { "$ref": "#/$defs/digest" }
      }
    }
  }
}
