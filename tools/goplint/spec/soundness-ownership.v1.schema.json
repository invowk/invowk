{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://invowk.dev/schemas/soundness-ownership.v1.schema.json",
  "title": "goplint soundness ownership",
  "type": "object",
  "additionalProperties": false,
  "required": ["format_version", "rules"],
  "properties": {
    "format_version": { "const": 1 },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pattern", "profile"],
        "properties": {
          "pattern": { "type": "string", "minLength": 1 },
          "profile": { "enum": ["consumer", "semantic"] }
        }
      }
    }
  }
}
