{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://invowk.dev/schemas/race-repeat-result.v1.schema.json",
  "title": "goplint race/repeat work result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version", "plan_id", "work_unit_id", "binary_digest",
    "expected_ids", "observed", "terminal_status", "output_digest"
  ],
  "properties": {
    "format_version": { "const": 1 },
    "plan_id": { "$ref": "#/$defs/digest" },
    "work_unit_id": { "type": "string", "minLength": 1 },
    "binary_digest": { "$ref": "#/$defs/digest" },
    "expected_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/member_id" },
      "uniqueItems": true
    },
    "observed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "runs", "passes", "fails", "skips"],
        "properties": {
          "id": { "$ref": "#/$defs/member_id" },
          "runs": { "type": "integer", "minimum": 0 },
          "passes": { "type": "integer", "minimum": 0 },
          "fails": { "type": "integer", "minimum": 0 },
          "skips": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "terminal_status": { "enum": ["passed", "failed", "timed-out", "canceled"] },
    "output_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "member_id": { "type": "string", "pattern": "^(Test|Fuzz|Example)[A-Za-z0-9_]*$" }
  }
}
