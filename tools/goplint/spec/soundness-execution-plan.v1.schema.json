{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://invowk.dev/schemas/goplint/soundness-execution-plan.v1.schema.json",
  "title": "goplint immutable soundness execution plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version",
    "plan_id",
    "profile",
    "workspace",
    "manifest",
    "registry",
    "toolchain",
    "resources",
    "commands",
    "dependencies",
    "censuses",
    "shards",
    "expected_reports"
  ],
  "properties": {
    "format_version": {
      "const": 1
    },
    "plan_id": {
      "$ref": "#/$defs/digest"
    },
    "profile": {
      "enum": [
        "complete",
        "consumer",
        "semantic"
      ]
    },
    "workspace": {
      "$ref": "#/$defs/workspace"
    },
    "manifest": {
      "$ref": "#/$defs/artifact"
    },
    "registry": {
      "$ref": "#/$defs/artifact"
    },
    "toolchain": {
      "$ref": "#/$defs/toolchain"
    },
    "resources": {
      "$ref": "#/$defs/resources"
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/command"
      }
    },
    "dependencies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/dependency"
      }
    },
    "censuses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/census"
      }
    },
    "shards": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/shard"
      }
    },
    "expected_reports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/expected_report"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\\\)(?!\\.\\.?/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "digest"
      ],
      "properties": {
        "root": {
          "const": "."
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "digest"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/path"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "go_version",
        "goos",
        "goarch",
        "digest"
      ],
      "properties": {
        "go_version": {
          "$ref": "#/$defs/identifier"
        },
        "goos": {
          "$ref": "#/$defs/identifier"
        },
        "goarch": {
          "$ref": "#/$defs/identifier"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpu_units",
        "memory_bytes",
        "maximum_workers",
        "runner_class",
        "serial_reference"
      ],
      "properties": {
        "cpu_units": {
          "type": "integer",
          "minimum": 1
        },
        "memory_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "maximum_workers": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1024
        },
        "runner_class": {
          "$ref": "#/$defs/identifier"
        },
        "serial_reference": {
          "type": "boolean"
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_unit_id",
        "subgate_id",
        "working_directory",
        "command",
        "command_digest",
		"binary_digest",
		"reserved_resources",
		"exclusivity_groups",
		"distributable",
		"timeout_seconds"
      ],
      "properties": {
        "work_unit_id": {
          "$ref": "#/$defs/identifier"
        },
        "subgate_id": {
          "$ref": "#/$defs/identifier"
        },
        "working_directory": {
          "$ref": "#/$defs/path"
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "command_digest": {
          "$ref": "#/$defs/digest"
        },
        "binary_digest": {
          "$ref": "#/$defs/digest"
		},
		"reserved_resources": {
		  "$ref": "#/$defs/reservation"
		},
		"exclusivity_groups": {
		  "type": "array",
		  "uniqueItems": true,
		  "items": {
			"$ref": "#/$defs/identifier"
		  }
		},
		"distributable": {
		  "type": "boolean"
		},
		"timeout_seconds": {
		  "type": "integer",
		  "minimum": 1,
		  "maximum": 86400
        }
      }
    },
	"reservation": {
	  "type": "object",
	  "additionalProperties": false,
	  "required": [
		"cpu_units",
		"memory_bytes",
		"worker_slots"
	  ],
	  "properties": {
		"cpu_units": {
		  "type": "integer",
		  "minimum": 1
		},
		"memory_bytes": {
		  "type": "integer",
		  "minimum": 1
		},
		"worker_slots": {
		  "type": "integer",
		  "minimum": 1
		}
	  }
	},
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_unit_id",
        "requires"
      ],
      "properties": {
        "work_unit_id": {
          "$ref": "#/$defs/identifier"
        },
        "requires": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        }
      }
    },
    "census": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "member_ids",
        "digest"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "kind": {
          "$ref": "#/$defs/identifier"
        },
        "member_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "shard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "work_unit_id",
        "census_id",
        "mode",
        "iteration",
        "member_ids",
        "total_weight",
        "timeout_seconds"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "work_unit_id": {
          "$ref": "#/$defs/identifier"
        },
        "census_id": {
          "$ref": "#/$defs/identifier"
        },
        "mode": {
          "$ref": "#/$defs/identifier"
        },
        "iteration": {
          "type": "integer",
          "minimum": 1
        },
        "member_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "total_weight": {
          "type": "integer",
          "minimum": 1
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400
        }
      }
    },
    "population_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "minimum"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "minimum": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "expected_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_unit_id",
        "subgate_id",
        "report_file",
        "command_digest",
        "required_registration_ids",
        "required_populations"
      ],
      "properties": {
        "work_unit_id": {
          "$ref": "#/$defs/identifier"
        },
        "subgate_id": {
          "$ref": "#/$defs/identifier"
        },
        "report_file": {
          "type": "string",
          "pattern": "^[^/\\\\]+\\.json$"
        },
        "command_digest": {
          "$ref": "#/$defs/digest"
        },
        "required_registration_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "required_populations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/population_requirement"
          }
        }
      }
    }
  }
}
