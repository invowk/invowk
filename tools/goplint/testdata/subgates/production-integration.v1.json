{
  "format_version": 1,
  "runs": [
    {
      "id": "production-tests",
      "packages": ["./goplint"],
      "tests": [
        "TestRealAnalyzerDeterminismAcrossPackageFileAndScheduleOrder",
        "TestProtocolProductionDomainReachability",
        "TestProtocolValidationCounterexamplesUseConditionalSuccessEdges",
        "TestProtocolUnknownEffectsAfterValidation",
        "TestTypedSSAAvailabilityDistinguishesFailureClasses",
        "TestRecursiveSummaryCFA",
        "TestGenericConstraintCastCFA",
        "TestSemanticEvidenceProduction",
        "TestProtocolProductionRoutingEvidence"
      ],
      "count": 1,
      "timeout_seconds": 600
    }
