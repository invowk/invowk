      "path": "openspec/changes/archive/2026-07-19-close-residual-goplint-soundness-gaps/evidence/targeted-mutation-run.v1.json"
    }
  ],
  "toolchain": [
    {
      "name": "git",
      "command": ["git", "--version"],
      "required_version_re": "^git version 2\\.55\\.0$"
    },
    {
      "name": "go",
      "command": ["go", "version"],
      "required_version_re": "^go version go1\\.26\\.[0-9]+ linux/amd64$"
    },
    {
      "name": "golangci-lint",
      "command": ["./scripts/golangci-lint.sh", "version"],
      "required_version_re": "^golangci-lint has version 2\\.12\\.2 .*$"
    },
    {
      "name": "make",
      "command": ["make", "--version"],
      "required_version_re": "^GNU Make 4\\.[0-9]+(\\.[0-9]+)?"
    }
  ],
  "task_ledgers": [
    {
      "name": "complete-goplint-soundness-hardening",
      "path": "openspec/changes/archive/2026-07-19-complete-goplint-soundness-hardening/tasks.md",
      "expected_pending": []
    },
    {
      "name": "close-goplint-soundness-review-gaps",
      "path": "openspec/changes/archive/2026-07-19-close-goplint-soundness-review-gaps/tasks.md",
      "expected_pending": []
    },
    {
      "name": "close-residual-goplint-soundness-gaps",
      "path": "openspec/changes/archive/2026-07-19-close-residual-goplint-soundness-gaps/tasks.md",
      "expected_pending": []
    },
    {
      "name": "accelerate-goplint-soundness-gates",
      "path": "openspec/changes/accelerate-goplint-soundness-gates/tasks.md",
      "expected_pending": ["10.2", "10.3", "10.7", "8.7"]
    }
  ],
  "diff_review": {
    "reviewed_exclusions": []
  },
  "counterexamples": {
    "path": "tools/goplint/testdata/gates/clean-tree-counterexamples-v3.json",
    "required": [
      {
        "id": "conditional-summary-result",
        "observation": "validation is restored only on the continuation proving the exact aliased helper result nil; discarded, overwritten, or mismatched results remain invalid or inconclusive"
      },
      {
        "id": "constructor-success-edge",
        "observation": "the else-edge return retains the object obligation and is a violation or blocking inconclusive"
      },
      {
        "id": "directive-validation",
        "observation": "one deterministic actionable unknown-directive diagnostic is emitted before any directive consumer runs"
      },
      {
        "id": "false-credit-category-evidence",
        "observation": "credit is accepted only when producer-emitted executed observations contain the claimed category, boundary, stages, dimensions, properties, and populations"
      },
      {
        "id": "hard-coded-subgate-populations",
        "observation": "the subgate fails before success unless every manifest member exists and is uniquely observed in the current run"
      },
      {
        "id": "imported-fact-shape",
        "observation": "the entire relevant fact is rejected and dependent analysis becomes blocking inconclusive"
      },
      {
        "id": "incomplete-diff-proof",
        "observation": "materialization and freshness verification fail until one v3 record binds the complete intended diff, all ledgers, artifacts, observations, and archive order"
      },
      {
        "id": "noncausal-mutation-attribution",
        "observation": "the mutant is invalid unless a structured observation proves the declared semantic mismatch after clean controls and exact restoration"
      },
      {
        "id": "package-stored-literal",
        "observation": "the package initializer literal is analyzed exactly once even without a visible call, or emits blocking inconclusive if its procedure identity is unresolved"
      },
      {
        "id": "post-validation-escape",
        "observation": "mutable escape invalidates proof or is blocking inconclusive; an alias-free immutable copy preserves validation"
      },
      {
        "id": "preclassification-suppression",
        "observation": "classification occurs first and the inconclusive diagnostic remains always visible"
      },
      {
        "id": "stable-id-global-identity",
        "observation": "IDs remain layout-stable, differ across full import paths, and collisions or duplicate emissions fail before baseline write"
      }
    ]
  },
  "commands": [
    {
      "name": "lint",
      "args": ["make", "lint"],
      "timeout_minutes": 40
    },
    {
      "name": "build",
      "args": ["make", "build", "build-goplint"],
      "timeout_minutes": 20
    },
    {
      "name": "root-tests",
      "args": ["make", "test"],
      "timeout_minutes": 90
    },
    {
      "name": "goplint-tests",
      "directory": "tools/goplint",
      "args": ["go", "test", "-count=1", "-timeout=20m", "./..."],
      "timeout_minutes": 30
    },
    {
      "name": "root-tidy-diff",
      "args": ["go", "mod", "tidy", "-diff"],
      "timeout_minutes": 10
    },
    {
      "name": "goplint-tidy-diff",
      "directory": "tools/goplint",
      "args": ["go", "mod", "tidy", "-diff"],
      "timeout_minutes": 10
    },
    {
      "name": "scheduled-fuzz",
      "args": ["make", "check-goplint-fuzz-scheduled"],
      "timeout_minutes": 30
    },
    {
      "name": "exceptions",
      "args": ["make", "check-goplint-exceptions"],
      "timeout_minutes": 20
    },
    {
      "name": "windows-build",
      "args": ["make", "check-windows-build"],
      "timeout_minutes": 20
    },
    {
      "name": "license",
      "args": ["make", "license-check"],
      "timeout_minutes": 10
    },
    {
      "name": "file-length",
      "args": ["make", "check-file-length"],
      "timeout_minutes": 10
    },
    {
      "name": "agent-docs",
      "args": ["make", "check-agent-docs"],
      "timeout_minutes": 10
    },
    {
      "name": "openspec-all",
      "args": ["openspec", "validate", "--all", "--strict", "--no-interactive"],
      "timeout_minutes": 10
    },
    {
      "name": "diff-check",
      "args": [
        "git",
        "diff",
        "--check",
        "HEAD^",
        "HEAD",
        "--",
        ".",
        ":(exclude)openspec/changes/archive/2026-07-19-close-residual-goplint-soundness-gaps/evidence/red-baseline-probes.v1.patch"
      ],
      "timeout_minutes": 10
    },
    {
      "name": "soundness-semantic",
      "args": ["make", "check-goplint-soundness-semantic"],
      "timeout_minutes": 180
    }
  ],
  "aggregate_report": {
    "command_name": "soundness-semantic",
    "output_file": "soundness-semantic.json",
    "manifest_path": "tools/goplint/spec/soundness-gate.v1.json",
    "registry_path": "tools/goplint/spec/semantic-evidence.v2.json",
    "profile": "semantic"
  },
  "mutation_proofs": [
    {
      "name": "missing-constructor-validate",
      "observation": "missing-constructor-validate.mutation"
    },
    {
      "name": "missing-constructor-validate-inconclusive",
