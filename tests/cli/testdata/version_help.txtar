# Test: invowk --version and invowk --help output
# These are the first commands new users run — verify they produce sensible output.

# Test 1: --version outputs a version string and license
exec invowk --version
stdout 'invowk version'
stdout 'License MPL-2.0: Mozilla Public License 2.0'
! stderr .

# Test 2: --help outputs usage information and license
exec invowk --help
stdout 'invowk'
stdout 'command runner'
stdout 'licensed under MPL-2.0'
! stderr .

# Test 3: invowk cmd --help shows cmd-specific help
exec invowk cmd --help
stdout 'invowk cmd'
stdout 'Execute commands'
! stderr .

# Test 4: hidden internal commands do not appear in --help output
exec invowk --help
! stdout 'internal'
! stderr .

# Test 5: invowk internal check-cmd works but is hidden
# (verifies internal commands are callable even though hidden from help)
! exec invowk internal check-cmd nonexistent-cmd-xyz
stderr 'not discoverable'
