# Test: invowk audit --severity filtering
# Verifies that --severity flag filters findings below threshold.
#
# This test uses env_inherit_mode: "none" to avoid implicit env inheritance
# findings that would correlate with network access and escalate to Critical.

cd $WORK

# Test 1: With --severity critical, medium network findings are excluded → exit 0
exec invowk audit --severity critical
stdout 'Security Audit'
stdout 'No confirmed findings at or above critical severity'

-- invowkfile.cue --
cmds: [{
    name: "fetch"
    description: "Fetch data"
    implementations: [{
        script: "wget https://example.com/data.json"
        runtimes: [{name: "virtual", env_inherit_mode: "none"}]
        platforms: [{name: "linux"}, {name: "macos"}, {name: "windows"}]
    }]
}]
