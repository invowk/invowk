# Test: multi-source discovery with 3 levels (native runtime mirror)
# Mirrors virtual_multi_source_full.txtar with platform-split native implementations.
# Exercises invowkfile + local module + vendored module discovery in a single scenario.

cd $WORK

# Test 1: List commands — should show commands from all 3 sources
exec invowk cmd
stdout 'local-cmd'
stdout 'mod-cmd'
stdout 'vendored-cmd'

# Test 2: Execute command from main invowkfile
exec invowk cmd local-cmd
stdout '^from invowkfile\r?$'
! stderr .

# Test 3: Execute command from local module
exec invowk cmd mod-cmd
stdout '^from local module\r?$'
! stderr .

# Test 4: Execute command from vendored module
exec invowk cmd vendored-cmd
stdout '^from vendored module\r?$'
! stderr .

-- invowkfile.cue --
cmds: [
	{
		name:        "local-cmd"
		description: "Command from main invowkfile"
		implementations: [
			{
				script:    "echo 'from invowkfile'"
				runtimes:  [{name: "native"}]
				platforms: [{name: "linux"}, {name: "macos"}]
			},
			{
				script:    "Write-Output 'from invowkfile'"
				runtimes:  [{name: "native"}]
				platforms: [{name: "windows"}]
			},
		]
	},
]

-- mymod.invowkmod/invowkmod.cue --
module:  "mymod"
version: "0.1.0"
requires: [
	{
		git_url: "https://github.com/example/dep.invowkmod.git"
		version: "^1.0.0"
	},
]

-- mymod.invowkmod/invowkfile.cue --
cmds: [
	{
		name:        "mod-cmd"
		description: "Command from local module"
		implementations: [
			{
				script:    "echo 'from local module'"
				runtimes:  [{name: "native"}]
				platforms: [{name: "linux"}, {name: "macos"}]
			},
			{
				script:    "Write-Output 'from local module'"
				runtimes:  [{name: "native"}]
				platforms: [{name: "windows"}]
			},
		]
	},
]

-- mymod.invowkmod/invowkmod.lock.cue --
version: "2.0"
generated: "2025-01-01T00:00:00Z"

modules: {
	"https://github.com/example/dep.invowkmod.git": {
		git_url:          "https://github.com/example/dep.invowkmod.git"
		version:          "^1.0.0"
		resolved_version: "1.0.0"
		git_commit:       "abc123def456789012345678901234567890abcd"
		namespace:        "dep@1.0.0"
		module_id:        "dep"
		content_hash:     "sha256:ebe6dbeee50a3f74055624ff5524ab02f4905d47bb2bffc20e74f9efc38c069d"
	}
}

-- mymod.invowkmod/invowk_modules/dep.invowkmod/invowkmod.cue --
module:  "dep"
version: "1.0.0"

-- mymod.invowkmod/invowk_modules/dep.invowkmod/invowkfile.cue --
cmds: [
	{
		name:        "vendored-cmd"
		description: "Command from vendored module"
		implementations: [
			{
				script:    "echo 'from vendored module'"
				runtimes:  [{name: "native"}]
				platforms: [{name: "linux"}, {name: "macos"}]
			},
			{
				script:    "Write-Output 'from vendored module'"
				runtimes:  [{name: "native"}]
				platforms: [{name: "windows"}]
			},
		]
	},
]
