# Execution Error Categories Flowchart
#
# Shows the main categories of errors that can occur during
# command execution and their common fixes.
#
# Source: internal/app/commandsvc/errors.go (classifyExecutionError)

vars: {
  d2-config: {
    layout-engine: tala
  }
}

direction: down

Start: Command execution failed {
  shape: oval
  style.fill: "#E8F5E9"
}

Classify: classifyExecutionError(err) {
  shape: diamond
  style.fill: "#FFF3E0"
}

# ==============================================================================
# Error Categories
# ==============================================================================

errors: Error Categories {
  style: {
    stroke: "#1168BD"
    stroke-dash: 3
    fill: transparent
  }

  E1: Execution Timed Out\nor Cancelled {
    style.fill: "#FFCDD2"
  }

  E2: Container Engine\nUnavailable {
    style.fill: "#FFCDD2"
  }

  E3: Runtime Unavailable {
    style.fill: "#FFCDD2"
  }

  E4: Shell Not Found {
    style.fill: "#FFCDD2"
  }

  E5: Permission Denied {
    style.fill: "#FFCDD2"
  }

  E6: Script Execution Failed {
    style.fill: "#FFCDD2"
  }
}

# ==============================================================================
# Fixes
# ==============================================================================

Fix1: Check timeout, cancellation,\nand script duration {
  style.fill: "#C8E6C9"
}

Fix2: Start Docker or Podman {
  style.fill: "#C8E6C9"
}

Fix3: Select an available runtime {
  style.fill: "#C8E6C9"
}

Fix4: Install the required shell {
  style.fill: "#C8E6C9"
}

Fix5: Check file and directory permissions {
  style.fill: "#C8E6C9"
}

Fix6: Check script content {
  style.fill: "#C8E6C9"
}

# ==============================================================================
# Connections
# ==============================================================================

Start -> Classify
Classify -> errors.E1: deadline or cancellation
Classify -> errors.E2: container engine unavailable
Classify -> errors.E3: runtime unavailable
Classify -> errors.E4: shell not found
Classify -> errors.E5: os.ErrPermission
Classify -> errors.E6: other execution error

errors.E1 -> Fix1: timed out or cancelled
errors.E2 -> Fix2: engine not running
errors.E3 -> Fix3: runtime cannot execute
errors.E4 -> Fix4: shell binary missing
errors.E5 -> Fix5: access denied
errors.E6 -> Fix6: script failure
