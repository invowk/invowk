# Native Runtime Availability Check Flowchart
#
# Shows how Invowk determines if the native runtime is available
# by using a configured shell override, then Unix SHELL env/bash/sh
# or Windows pwsh/powershell/cmd.
#
# Source: docs/architecture/flowchart-runtime-selection.md

vars: {
  d2-config: {
    layout-engine: tala
  }
}

direction: right

Start: Check Native {
  shape: oval
  style.fill: "#E8F5E9"
}

Configured: Configured shell? {
  shape: diamond
  style.fill: "#FFF3E0"
}

UseConfigured: Use configured shell

Unix: Unix-like OS? {
  shape: diamond
  style.fill: "#FFF3E0"
}

FindShell: Check SHELL env,\nthen bash,\nthen sh

FindWinShell: Check pwsh,\nthen powershell,\nthen cmd

HasShell: Found? {
  shape: diamond
  style.fill: "#FFF3E0"
}

HasWinShell: Found? {
  shape: diamond
  style.fill: "#FFF3E0"
}

Available: Available {
  shape: oval
  style.fill: "#C8E6C9"
}

Unavailable: Unavailable {
  shape: oval
  style.fill: "#FFCDD2"
}

Start -> Configured
Configured -> UseConfigured: Yes
Configured -> Unix: No
UseConfigured -> Available
Unix -> FindShell: Yes
Unix -> FindWinShell: No
FindShell -> HasShell
FindWinShell -> HasWinShell
HasShell -> Available: Yes
HasShell -> Unavailable: No
HasWinShell -> Available: Yes
HasWinShell -> Unavailable: No
