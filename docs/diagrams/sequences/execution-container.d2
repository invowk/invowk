# Container Runtime Execution Sequence Diagram
#
# Detailed flow for container runtime execution including:
# - CommandService orchestration through host access, registry, and interactive ports
# - Image validation and base image resolution
# - Ephemeral layer provisioning (separate from base image)
# - Ephemeral run or persistent target lifecycle
# - Execution with retry
# - Cleanup of runtime resources while persistent containers remain
#
# Source: internal/app/commandsvc, internal/app/commandadapters,
# internal/runtime/container_exec.go, container_provision.go

vars: {
  d2-config: {
    layout-engine: tala
  }
}

title: |md
  ## Container Runtime Execution Sequence
|

shape: sequence_diagram

# Participants
SVC: Command Service
HostAccess: Host Access Adapter
RegistryFactory: Runtime Registry Factory
Interactive: Interactive Adapter
SSH: SSH Server
ServerBase: Server Lifecycle Base
TUI: TUI Server
TUIWire: TUI Wire Protocol
ContainerRT: Container Runtime
Engine: Engine Abstraction
Provision: Layer Provisioner
Container: Docker/Podman

# 0. Commandsvc reaches this point only after runtime resolution, context build,
# and the dry-run gate. Dry-run returns before host access, registry setup, or containers.
SVC -> SVC: "Resolve runtime + build execution context"
SVC -> SVC: "If --ivk-dry-run: return plan\n(no host access, registry, or container side effects)" {
  style.stroke-dash: 3
  style.font-color: "#666666"
}

# 0a. Host access is a port. The default adapter owns the SSH server lifecycle.
SVC -> HostAccess: "Ensure(ctx)\nif enable_host_ssh"
HostAccess -> SSH: Start (if needed)
SSH -> ServerBase: "TransitionToStarting\nAdd goroutine"
ServerBase -> SSH: "Running / failed state"
SSH -> HostAccess: Ready
HostAccess -> SVC: Ready / no-op

# 0b. Registry construction is a port. The adapter forwards the active SSH reference.
SVC -> RegistryFactory: "Create(cfg, hostAccess)"
RegistryFactory -> HostAccess: "SSHServer()\nif active"
HostAccess -> RegistryFactory: SSH reference
RegistryFactory -> ContainerRT: SetSSHServer(reference) {
  style.stroke-dash: 3
  style.font-color: "#666666"
}
RegistryFactory -> SVC: Runtime registry + cleanup
SVC -> SVC: Validate dependencies with selected runtime

# 1. Preparation Phase
SVC -> ContainerRT: "Execute(context)\nstandard mode"

# Interactive orchestration is a separate port and injects TUI env only for attached runs.
SVC -> Interactive: "Execute(context, runtime)\ninteractive mode only" {
  style.stroke-dash: 3
  style.font-color: "#666666"
}
Interactive -> TUI: Start {
  style.stroke-dash: 3
  style.font-color: "#666666"
}
TUI -> ServerBase: "TransitionToStarting\nAdd goroutine" {
  style.stroke-dash: 3
  style.font-color: "#666666"
}
ServerBase -> TUI: "Running / failed state" {
  style.stroke-dash: 3
  style.font-color: "#666666"
}
TUI -> Interactive: URL + token {
  style.stroke-dash: 3
  style.font-color: "#666666"
}
TUI -> TUIWire: "Serve /tui JSON envelopes\nand INVOWK_TUI_* names" {
  style.stroke-dash: 3
  style.font-color: "#666666"
}
Interactive -> ContainerRT: "PrepareInteractive(context with INVOWK_TUI_*)" {
  style.stroke-dash: 3
  style.font-color: "#666666"
}
ContainerRT -> TUIWire: "Pass component env\ninto container" {
  style.stroke-dash: 3
  style.font-color: "#666666"
}

# 1a. Image validation (rejects Alpine/Windows before any work)
ContainerRT -> ContainerRT: validateSupportedContainerImage()

# 1b. Base image resolution (ContainerRT owns this, NOT Provisioner)
ContainerRT -> Engine: Image exists? (or build from Containerfile)

# Pull/build if missing (conditional)
Engine -> Container: Pull image / docker build (if needed)
Container -> Engine: Image ready
Engine -> ContainerRT: Base image tag

# 1c. Ephemeral layer provisioning (adds invowk binary + modules)
ContainerRT -> Provision: Provision(baseImage)
Provision -> Provision: Create ephemeral layer (Dockerfile)
Provision -> Engine: Build provisioned image
Engine -> Container: docker build
Container -> Engine: Image built
Provision -> ContainerRT: Provisioned image tag

# 2. Runtime setup
ContainerRT -> ContainerRT: "Build env + INVOWK_SSH_*\nif host access reference is active"

# 3. Persistent target selection (optional)
ContainerRT -> ContainerRT: "Resolve persistent target\nCLI > config name > derived invowk-*"
ContainerRT -> Engine: "Inspect container\nif persistent requested" {
  style.stroke-dash: 3
  style.font-color: "#666666"
}
Engine -> Container: "docker/podman container inspect" {
  style.stroke-dash: 3
  style.font-color: "#666666"
}
ContainerRT -> Engine: "Create + start managed target\nif missing and create_if_missing" {
  style.stroke-dash: 3
  style.font-color: "#666666"
}
Engine -> Container: "docker/podman create/start" {
  style.stroke-dash: 3
  style.font-color: "#666666"
}

# 4. Execution Phase
ContainerRT -> Engine: "Run ephemeral container\nor exec persistent target"
Engine -> Container: "docker/podman run --rm\nor docker/podman exec"
Container -> Engine: Exit code, output
Engine -> ContainerRT: Result

# 5. Cleanup Phase
# Runtime cleanup (tokens/temp files/provision resources)
ContainerRT -> ContainerRT: "Cleanup runtime resources\npersistent containers remain"

# Return
ContainerRT -> SVC: Result
Interactive -> TUI: Stop (interactive only) {
  style.stroke-dash: 3
  style.font-color: "#666666"
}
SVC -> HostAccess: Stop (if this execution started it)
HostAccess -> SSH: Stop
