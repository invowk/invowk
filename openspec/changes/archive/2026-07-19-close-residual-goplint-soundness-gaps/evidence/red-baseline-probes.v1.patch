+// SPDX-License-Identifier: MPL-2.0
+
+package goplint
+
+import "testing"
+
+func TestResidualImportedFactsBindFunctionSlotsRolesAndTypes(t *testing.T) {
+	t.Parallel()
+
+	base := ProtocolSummaryFact{
+		FormatVersion: protocolSummaryFactVersion,
+		PackagePath:   "example.com/probe",
+		FunctionName:  "Helper",
+		Complete:      true,
+		Effects: []ProtocolSummaryEffectFact{{
+			Kind:                protocolSummaryEffectValidate,
+			TargetKind:          protocolSummaryTargetParameter,
+			TargetSlot:          0,
+			SourceSlot:          -1,
+			ConditionResultSlot: 1,
+			Condition:           protocolSummaryConditionResultNil,
+		}},
+	}
+	tests := []struct {
+		name   string
+		mutate func(*ProtocolSummaryFact)
+	}{
+		{name: "wrong-function", mutate: func(fact *ProtocolSummaryFact) { fact.FunctionName = "Other" }},
+		{name: "target-slot", mutate: func(fact *ProtocolSummaryFact) { fact.Effects[0].TargetSlot = 99 }},
+		{name: "target-role", mutate: func(fact *ProtocolSummaryFact) { fact.Effects[0].TargetKind = protocolSummaryTargetReceiver }},
+		{name: "condition-slot", mutate: func(fact *ProtocolSummaryFact) { fact.Effects[0].ConditionResultSlot = 99 }},
+		{name: "condition-type", mutate: func(fact *ProtocolSummaryFact) { fact.Effects[0].ConditionResultSlot = 0 }},
+	}
+	for _, test := range tests {
+		t.Run(test.name, func(t *testing.T) {
+			fact := base
+			fact.Effects = append([]ProtocolSummaryEffectFact(nil), base.Effects...)
+			test.mutate(&fact)
+			if got := validateProtocolSummaryFact(&fact, base.PackagePath); got != protocolSummaryFactIncompatible {
+				t.Fatalf("malformed attached fact status = %d, want incompatible; fact=%+v", got, fact)
+			}
+		})
+	}
+}

