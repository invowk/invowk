+// SPDX-License-Identifier: MPL-2.0
+
+package main
+
+import (
+	"os"
+	"os/exec"
+	"path/filepath"
+	"testing"
+)
+
+func TestResidualCleanTreeRejectsOmittedDirtyPaths(t *testing.T) {
+	t.Parallel()
+
+	root := t.TempDir()
+	runGitForResidualProbe(t, root, "init")
+	writeResidualProbeFile(t, filepath.Join(root, "included.txt"), "base\n")
+	writeResidualProbeFile(t, filepath.Join(root, "omitted.txt"), "base\n")
+	runGitForResidualProbe(t, root, "add", "included.txt", "omitted.txt")
+	runGitForResidualProbe(t, root, "-c", "user.name=goplint probe", "-c", "user.email=probe@invalid", "commit", "-m", "base")
+
+	writeResidualProbeFile(t, filepath.Join(root, "included.txt"), "selected change\n")
+	writeResidualProbeFile(t, filepath.Join(root, "omitted.txt"), "silently omitted change\n")
+	writeResidualProbeFile(t, filepath.Join(root, "paths.txt"), "included.txt\n")
+	writeResidualProbeFile(t, filepath.Join(root, "plan.json"), `{"format_version":1,"commands":[{"name":"clean","args":["git","status","--porcelain"],"timeout_minutes":1}]}`)
+
+	if err := captureEvidence(root, "paths.txt", "plan.json", "evidence"); err == nil {
+		t.Fatal("clean-tree capture accepted a reviewed path list that omitted a dirty tracked path")
+	}
+}
+
+func runGitForResidualProbe(t *testing.T, directory string, args ...string) {
+	t.Helper()
+	command := exec.Command("git", args...)
+	command.Dir = directory
+	if output, err := command.CombinedOutput(); err != nil {
+		t.Fatalf("git %v failed: %v: %s", args, err, output)
+	}
+}
+
+func writeResidualProbeFile(t *testing.T, path, content string) {
+	t.Helper()
+	if err := os.WriteFile(path, []byte(content), 0o600); err != nil {
+		t.Fatalf("os.WriteFile(%s) error: %v", path, err)
+	}
+}
