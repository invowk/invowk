+// SPDX-License-Identifier: MPL-2.0
+
+package goplint
+
+import (
+	"go/token"
+	"go/types"
+	"testing"
+
+	"golang.org/x/tools/go/analysis"
+)
+
+func TestResidualStableIDIgnoresLeafAndRawLayout(t *testing.T) {
+	t.Parallel()
+
+	t.Run("package-leaf-rename", func(t *testing.T) {
+		left := &analysis.Pass{Pkg: types.NewPackage("example.com/stable/shared", "shared")}
+		renamed := &analysis.Pass{Pkg: types.NewPackage("example.com/stable/shared", "renamed")}
+		leftID := PackageScopedFindingID(left, CategoryPrimitive, "shared.Value.Name", "string")
+		renamedID := PackageScopedFindingID(renamed, CategoryPrimitive, "renamed.Value.Name", "string")
+		if leftID != renamedID {
+			t.Fatalf("package leaf rename changed full-import-path finding ID: %q != %q", leftID, renamedID)
+		}
+	})
+
+	t.Run("raw-source-layout", func(t *testing.T) {
+		leftSet := token.NewFileSet()
+		leftFile := leftSet.AddFile("probe.go", -1, 32)
+		left := stablePosKey(&analysis.Pass{Fset: leftSet}, leftFile.Pos(5))
+
+		rightSet := token.NewFileSet()
+		rightFile := rightSet.AddFile("probe.go", -1, 32)
+		rightFile.AddLine(3)
+		right := stablePosKey(&analysis.Pass{Fset: rightSet}, rightFile.Pos(5))
+		if left != right {
+			t.Fatalf("unrelated layout changed semantic site key: %q != %q", left, right)
+		}
+	})
+}

