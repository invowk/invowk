+		AggregateTarget: "soundness",
+		Checks: []gateContractCheck{{
+			Target:   "semantic",
+			Evidence: "semantic.sh",
+			Markers:  []string{"TestNeverExecuted"},
+			Tests:     []gateContractTest{{Name: "TestNeverExecuted", Evidence: "semantic_test.go"}},
+		}},
+		NonVacuityMarkers:  []gateContractMarker{{Evidence: "semantic_test.go", Marker: "TestNeverExecuted"}},
+		RequiredCITriggers: []string{"tools/goplint/**"},
+	}
+	files := map[string]string{
+		"Makefile":                   "soundness: semantic\nsemantic:\n\ttrue\n",
+		"semantic.sh":                "# TestNeverExecuted is only a marker; no test command runs it\ntrue\n",
+		"semantic_test.go":           "package probe\n\nfunc TestNeverExecuted(t *testing.T) {}\n",
+		".github/workflows/lint.yml": "tools/goplint/**",
+	}
+	if err := validateContract(contract, ".", mapReader(files)); err == nil {
+		t.Fatal("definition and string markers received subgate credit without a current-run execution census")
+	}
