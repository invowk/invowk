+// SPDX-License-Identifier: MPL-2.0
+
+package goplint
+
+import (
+	"encoding/json"
+	"os"
+	"testing"
+)
+
+func TestResidualEvidenceRejectsMarkerOnlyFalseCredit(t *testing.T) {
+	t.Parallel()
+
+	catalogData, err := os.ReadFile(semanticRulesCatalogPath())
+	if err != nil {
+		t.Fatalf("os.ReadFile(semanticRulesCatalogPath()) error: %v", err)
+	}
+	var catalog semanticCoverageCatalog
+	if err := json.Unmarshal(catalogData, &catalog); err != nil {
+		t.Fatalf("json.Unmarshal(catalog) error: %v", err)
+	}
+
+	moduleRoot := t.TempDir()
+	const marker = "marker-only-evidence"
+	if err := os.WriteFile(moduleRoot+"/marker.txt", []byte(marker), 0o600); err != nil {
+		t.Fatalf("os.WriteFile(marker.txt) error: %v", err)
+	}
+	evidence := semanticEvidenceRegistry()
+	for index := range evidence {
+		evidence[index].Artifact = "marker.txt"
+		evidence[index].Marker = marker
+	}
+
+	if _, err := buildSemanticCoverageCensus(catalog, moduleRoot, semanticOwnerRegistry(), evidence); err == nil {
+		t.Fatal("marker-only evidence received semantic coverage credit; want rejection")
+	}
+}

